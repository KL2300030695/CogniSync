# ─── EventFlow AI — Environment Variables ───

# Required: Google Gemini AI (get at aistudio.google.com)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Firebase (Real-time sync + Auth)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# Google Analytics 4
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Google Maps (venue navigation)
VITE_GOOGLE_MAPS_KEY=your_maps_key

# Optional: Google Cloud TTS (audio advisories)
VITE_GOOGLE_TTS_KEY=your_tts_key
